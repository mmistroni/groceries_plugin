{
  "name": "Claude Code Workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  // FIX: We completely emptied the "features" block. 
  // Codespaces already includes common utilities, git, zsh, and users by default.
  // Leaving this empty bypasses the broken Yarn/Debian GPG update script.
  "features": {},
  
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  
  // PERSISTENCE FIX: This creates a hidden directory inside your persistent repository 
  // and symlinks it to where Claude saves its login session, so restarts don't log you out.
  "postCreateCommand": "mkdir -p /workspaces/${localWorkspaceFolderBasename}/.claude_config && mkdir -p ~/.config && ln -sf /workspaces/${localWorkspaceFolderBasename}/.claude_config ~/.config/claude",
  
  "postStartCommand": "echo 'Container ready! Run \"claude\" in the terminal to begin.'"
}
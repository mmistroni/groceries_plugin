{
  "name": "Claude Code Workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  
  // CLAUDE CONFIG PERSISTENCE: Retains your Claude session across restarts
  "postCreateCommand": "mkdir -p /workspaces/${localWorkspaceFolderBasename}/claude_project/.claude_config && mkdir -p ~/.config && ln -sf /workspaces/${localWorkspaceFolderBasename}/claude_project/.claude_config ~/.config/claude",
  
  "postStartCommand": "echo 'Container ready instantly! Run: cd claude_project && npm run dev'"
}